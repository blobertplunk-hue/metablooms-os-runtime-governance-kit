{
  "schema_version": "1.0.0",
  "policy_id": "CONFLICT_RESOLUTION_POLICY_v1",
  "purpose": "Make conflicts visible, durable, and recoverable instead of silently overwriting concurrent work.",
  "conflict_packet_path": "coordination/conflicts/",
  "required_conflict_packet_fields": [
    "conflict_id",
    "detected_at",
    "detected_by",
    "stage_id",
    "lane_id",
    "paths",
    "base_hashes",
    "ours_hashes",
    "theirs_hashes",
    "recommended_resolution",
    "blocked_until"
  ],
  "allowed_resolutions": [
    "accept_ours",
    "accept_theirs",
    "manual_merge",
    "split_paths",
    "rebase_packet",
    "defer_lane",
    "abandon_packet"
  ],
  "forbidden_resolutions": [
    "silent_overwrite",
    "delete_without_tombstone",
    "advance_next_stage_without_receipt"
  ],
  "operator_visibility": "conflicts must appear in recovery/DASHBOARD.md and Issue #5 until resolved"
}
