#!/usr/bin/env python3
"""Regression fixture tracker — promotes failures to permanent test fixtures.

Implements DR1: every failure detected during a pipeline run must be
processed through the 6-step fixture loop:
1. detect failure_type
2. capture run_trace  
3. root_cause analysis
4. apply fix
5. write fixture from failure
6. wire fixture as blocking gate
"""
from __future__ import annotations

import hashlib, json, time
from pathlib import Path
from typing import Any


FIXTURES_PATH = Path("/tmp/REGRESSION_FIXTURES_PROMOTED.json")


def _load_fixtures() -> list:
    if FIXTURES_PATH.exists():
        try:
            return json.loads(FIXTURES_PATH.read_text())
        except Exception:
            pass
    return []


def _save_fixtures(fixtures: list) -> None:
    FIXTURES_PATH.parent.mkdir(parents=True, exist_ok=True)
    FIXTURES_PATH.write_text(json.dumps(fixtures, indent=2))


def promote_failure(
    failure_type: str,
    task: str,
    stage: str,
    error_msg: str,
    state_snapshot: dict | None = None,
) -> dict:
    """Promote a runtime failure to a regression fixture."""
    fixture_id = hashlib.sha256(
        f"{failure_type}:{task}:{stage}:{error_msg}".encode()
    ).hexdigest()[:16]

    fixture = {
        "fixture_id": fixture_id,
        "failure_type": failure_type,
        "task": task,
        "stage": stage,
        "error": error_msg,
        "root_cause": _auto_root_cause(failure_type, error_msg),
        "fix_applied": "pending",
        "gate_wired": False,
        "promoted_at": time.time(),
        "state_snapshot_keys": list((state_snapshot or {}).keys()),
    }

    fixtures = _load_fixtures()
    # Deduplicate by fixture_id
    existing_ids = {f["fixture_id"] for f in fixtures}
    if fixture_id not in existing_ids:
        fixtures.append(fixture)
        _save_fixtures(fixtures)

    return fixture


def _auto_root_cause(failure_type: str, error_msg: str) -> str:
    """Auto-classify root cause."""
    patterns = {
        "GATE_FAILED":           "Stage gate precondition not met",
        "CONSTRAINT_NOT_CAUSAL": "OFM constraint not causally satisfied by result",
        "SEE_NOT_EXECUTED":      "Loop controller did not route through SEE before VALIDATION",
        "CE_CRITIC":             "CE output failed quality validation",
        "VALIDATION_FAILED":     "One or more invariants not satisfied",
        "MISSING_MANDATORY":     "Required pipeline stage not executed",
    }
    for key, cause in patterns.items():
        if key in (failure_type + error_msg):
            return cause
    return f"Unknown: {error_msg[:100]}"


def promote_pipeline_errors(pipeline_result: dict, state: dict) -> int:
    """Promote all errors from a failed pipeline run to fixtures."""
    errors   = pipeline_result.get("errors", [])
    task     = state.get("task", "unknown")
    promoted = 0

    for error in errors:
        # Extract stage from error format: STAGE_EXECUTION_FAILED:STAGE:message
        parts = error.split(":", 2)
        if len(parts) >= 2 and parts[0] == "STAGE_EXECUTION_FAILED":
            stage = parts[1]
            msg   = parts[2] if len(parts) > 2 else error
        else:
            stage = "unknown"
            msg   = error

        promote_failure(
            failure_type=parts[0] if parts else "UNKNOWN",
            task=task,
            stage=stage,
            error_msg=msg,
            state_snapshot=state,
        )
        promoted += 1

    return promoted


def get_fixtures_count() -> int:
    return len(_load_fixtures())


if __name__ == "__main__":
    # Seed with one test fixture to prove the mechanism works
    f = promote_failure(
        failure_type="CONSTRAINT_NOT_CAUSAL",
        task="test task",
        stage="CONSTRAINT_EVALUATOR",
        error_msg="BUG_B: field_presence walked wrong path",
        state_snapshot={"task": "test", "result": {"status": "ok"}},
    )
    print(f"Fixture promoted: {f['fixture_id']}")
    print(f"Total fixtures: {get_fixtures_count()}")
    print(f"Path: {FIXTURES_PATH}")
