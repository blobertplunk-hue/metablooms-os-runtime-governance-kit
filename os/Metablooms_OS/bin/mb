    mve = root / '0_kernel/registry/evals/EVALS_MINIMUM_VIABLE_EVAL_LOOP_v1.json'
    sample_set = root / 'runtime/evals/evals_trace_review/EVALS_TRACE_SAMPLE_SET_v1.json'
    validation = root / 'runtime/evals/evals_trace_review/EVALS_TRACE_REVIEW_STAGE1_VALIDATION_LATEST.json'
    scorecard_spec = root / '0_kernel/registry/evals/MB_EVALS_SCORECARD_SPEC_v1.json'
    failure_modes = root / '0_kernel/registry/evals/EVALS_FAILURE_MODE_CATALOG_v1.json'
    regression_dataset = root / 'runtime/evals/evals_trace_review/EVALS_REGRESSION_DATASET_v1.json'
    scorecard_baseline = root / 'runtime/evals/evals_trace_review/EVALS_SCORECARD_BASELINE_v1.json'
    stage2_validation = root / 'runtime/evals/evals_trace_review/EVALS_SCORECARDS_STAGE2_VALIDATION_LATEST.json'
    runner_spec = root / '0_kernel/registry/evals/MB_EVALS_EVALUATOR_RUNNER_SPEC_v1.json'
    matrix_schema = root / '0_kernel/registry/evals/EVALS_CONFUSION_MATRIX_SCHEMA_v1.json'
