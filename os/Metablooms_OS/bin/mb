#!/usr/bin/env python3
"""MetaBlooms compact operator CLI.

Small, stable command surface for boot/status/verify/export/replay/doctor/run-stage
so operators do not need dense prompt incantations for the critical path.
"""
from __future__ import annotations
import argparse, json, os, subprocess, sys, time, hashlib, zipfile
from pathlib import Path

SCHEMA_VERSION = 'MB_CLI_OUTPUT_v25'


def utc_now() -> str:
    return time.strftime('%Y%m%dT%H%M%SZ', time.gmtime())


def find_root() -> Path:
    here = Path(__file__).resolve()
    for parent in [here.parent, *here.parents]:
        if (parent / 'boot_manifest_v1.json').exists() and (parent / '0_kernel').exists():
            return parent
    env = os.environ.get('METABLOOMS_ROOT')
    if env and (Path(env) / 'boot_manifest_v1.json').exists():
        return Path(env)
    cwd = Path.cwd()
    if (cwd / 'boot_manifest_v1.json').exists() and (cwd / '0_kernel').exists():
        return cwd
    raise SystemExit('METABLOOMS_ROOT_NOT_FOUND')


def latest_file(root: Path, patterns):
    matches = []
    for pat in patterns:
        matches.extend(root.glob(pat))
    matches = [p for p in matches if p.is_file()]
    if not matches:
        return None
    return str(max(matches, key=lambda p: p.stat().st_mtime))


def write_json(path: Path, payload: dict) -> str:
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(json.dumps(payload, indent=2, sort_keys=True) + '\n', encoding='utf-8')
    return str(path)


def emit(obj, as_json: bool):
    obj.setdefault('schema_version', SCHEMA_VERSION)
    if as_json:
        print(json.dumps(obj, indent=2, sort_keys=True))
        return
    verdict = obj.get('verdict') or obj.get('status') or 'OK'
    print(f"MetaBlooms: {verdict}")
    for k in ['root','boot_verdict','accepted_warning','latest_receipt','latest_handoff','next_stage','stage_name','thread_id','checkpoint_id','work_order_path','tracker_preview_path','export_path']:
        if obj.get(k) is not None:
            print(f"{k}: {obj[k]}")
    if obj.get('failed_checks'):
        print('failed_checks: ' + ', '.join(obj['failed_checks']))
    if obj.get('warnings'):
        print('warnings: ' + ', '.join(str(x) for x in obj['warnings']))
    if obj.get('tracker_preview'):
        print('tracker_preview:')
        for line in obj['tracker_preview']:
            print(f'  {line}')




def safe_load_json(path: Path):
    try:
        return json.loads(path.read_text(encoding='utf-8'))
    except Exception as e:
        return {'parse_error': str(e), 'path': str(path)}


def stage_thread_id(stage_name: str) -> str:
    cleaned = ''.join(ch if ch.isalnum() or ch in ('_', '-') else '_' for ch in stage_name.strip())[:80]
    return f"stage::{cleaned or 'UNNAMED'}"


def checkpoint_id_for(stage_name: str) -> str:
    seed = f"{stage_name}|{utc_now()}"
    return hashlib.sha256(seed.encode('utf-8')).hexdigest()[:16]


def render_tracker_preview(root: Path, limit: int = 8):
    tracker_path = root / 'runtime/state/TRACKER_STATE_v1.json'
    state = safe_load_json(tracker_path) if tracker_path.exists() else {'missing': True, 'path': str(tracker_path)}
    history = state.get('history', []) if isinstance(state, dict) else []
    completed = state.get('completed_stages', []) if isinstance(state, dict) else []
    lines = []
    lines.append(f"current_stage: {state.get('current_stage') if isinstance(state, dict) else None}")
    lines.append(f"completed_count: {len(completed) if isinstance(completed, list) else 0}")
    lines.append(f"blocker: {state.get('blocker') if isinstance(state, dict) else None}")
    ev = state.get('evidence', {}) if isinstance(state, dict) else {}
    if isinstance(ev, dict):
        lines.append(f"latest_receipt: {ev.get('latest_receipt')}")
        lines.append(f"latest_handoff: {ev.get('latest_handoff')}")
    if history:
        lines.append('recent_history:')
        for item in history[-limit:]:
            if isinstance(item, dict):
                lines.append(f"- {item.get('timestamp_utc', '?')} {item.get('stage', '?')} [{item.get('status', '?')}]")
    return {
        'tracker_state_path': str(tracker_path),
        'tracker_state_present': tracker_path.exists(),
        'current_stage': state.get('current_stage') if isinstance(state, dict) else None,
        'completed_count': len(completed) if isinstance(completed, list) else 0,
        'blocker': state.get('blocker') if isinstance(state, dict) else None,
        'preview_lines': lines,
    }


def command_status(args):
    root = find_root()
    pointer = root / 'CURRENT_FULL_AUTHORITY_POINTER_v1.json'
    authority = None
    if pointer.exists():
        try:
            authority = json.loads(pointer.read_text(encoding='utf-8'))
        except Exception as e:
            authority = {'parse_error': str(e)}
    latest_receipt = latest_file(root, ['runtime/receipts/**/*.json','receipts/**/*.json','0_kernel/registry/boot_receipts/*.json'])
    latest_handoff = latest_file(root, ['runtime/handoffs/**/*.json','handoffs/**/*.json'])
    out = {
        'status': 'READY_FOR_BOUNDED_STAGE',
        'root': str(root),
        'authority_pointer_present': pointer.exists(),
        'authority': authority,
        'latest_receipt': latest_receipt,
        'latest_handoff': latest_handoff,
        'critical_commands': ['mb boot', 'mb status', 'mb verify', 'mb doctor', 'mb run-stage <name> --dry-run', 'mb export --output <zip>', 'mb replay', 'mb evals --check', 'mb evals --scorecards', 'mb evals --runner', 'mb evals --confusion', 'mb evals --alignment-gate', 'mb evals --promotion'],
    }
    emit(out, args.json)


def command_boot(args):
    root = find_root()
    script = root / '0_kernel/scripts/boot_runtime_executor_v1.py'
    if not script.exists():
        script = root / 'portable_full_os_boot_verify.py'
    if not script.exists():
        raise SystemExit('BOOT_EXECUTOR_NOT_FOUND')
    cmd = ['python3','-S',str(script)]
    proc = subprocess.run(cmd, cwd=str(root), text=True, capture_output=True, timeout=args.timeout)
    receipt_path = None
    parsed = None
    try:
        parsed = json.loads(proc.stdout.strip())
        receipt_path = parsed.get('receipt_path')
    except Exception:
        try:
            start = proc.stdout.find('{')
            end = proc.stdout.rfind('}')
            parsed = json.loads(proc.stdout[start:end+1]) if start >= 0 and end >= start else None
            receipt_path = parsed.get('receipt_path') if isinstance(parsed, dict) else None
        except Exception:
            parsed = None
    out = {
        'verdict': 'BOOT_COMMAND_PASS' if proc.returncode == 0 else 'BOOT_COMMAND_FAIL',
        'root': str(root),
        'boot_executor': str(script),
        'returncode': proc.returncode,
        'stdout_tail': proc.stdout[-2000:],
        'stderr_tail': proc.stderr[-2000:],
        'boot_verdict': parsed.get('verdict') if isinstance(parsed, dict) else None,
        'accepted_warning': 'git_dir_missing' if (isinstance(parsed, dict) and 'git_dir_missing' in parsed.get('warnings', [])) else None,
        'latest_receipt': receipt_path,
    }
    emit(out, args.json)
    return 0 if proc.returncode == 0 else proc.returncode


