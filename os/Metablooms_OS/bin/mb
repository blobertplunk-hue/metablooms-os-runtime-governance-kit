def command_replay(args):
    root = find_root()
    handoff = latest_file(root, ['runtime/handoffs/**/*.json','handoffs/**/*.json'])
    payload = None
    if handoff:
        try:
            payload = json.loads(Path(handoff).read_text(encoding='utf-8'))
        except Exception as e:
            payload = {'parse_error': str(e)}
    next_stage = None
    if isinstance(payload, dict):
        next_stage = payload.get('next_stage') or payload.get('recommended_next_stage') or payload.get('next_valid_step')
    out = {
        'verdict': 'REPLAY_DRY_RUN_READY' if handoff else 'REPLAY_NO_HANDOFF_FOUND',
        'root': str(root),
        'latest_handoff': handoff,
        'next_stage': next_stage,
        'dry_run': True,
        'resume_rule': 'Run one bounded stage from this handoff; do not trust chat-only state.',
    }
    emit(out, args.json)
    return 0


def command_doctor(args):
    root = find_root()
    checks = []
    def add(check_id, ok, severity, evidence=None, remediation=None):
        checks.append({'id': check_id, 'ok': bool(ok), 'severity': severity, 'evidence': evidence, 'remediation': remediation})
    add('root_detected', root.exists(), 'critical', str(root), 'Set METABLOOMS_ROOT or run from extracted OS root.')
    add('boot_manifest_present', (root/'boot_manifest_v1.json').exists(), 'critical', 'boot_manifest_v1.json', 'Restore boot manifest from authority bundle.')
    boot_exec = root/'0_kernel/scripts/boot_runtime_executor_v1.py'
    add('boot_executor_present', boot_exec.exists(), 'critical', str(boot_exec), 'Restore boot executor before booting.')
    add('operator_cli_present', (root/'bin/mb').exists(), 'critical', '0_kernel/registry/filesystem_handling/FILESYSTEM_HANDLING_SAFETY_POLICY_v1.json',
        '0_kernel/registry/filesystem_handling/FILESYSTEM_HANDLING_SAFETY_POLICY_v2.json',
        '0_kernel/lib/archive_extraction_route_v1.py',
        '0_kernel/validators/validate_filesystem_handling_safety_stage2_v1.py', 'Restore operator CLI.')
    add('operator_spec_v2_present', (root/'0_kernel/registry/operator_surface/MB_CLI_COMMAND_SPEC_v2.json').exists(), 'critical', 'MB_CLI_COMMAND_SPEC_v2.json', 'Run Stage 2 integration again.')
    add('stage2_validator_present', (root/'0_kernel/validators/validate_operator_surface_stage2_v1.py').exists(), 'critical', 'validate_operator_surface_stage2_v1.py', 'Restore Stage 2 validator.')
    add('archive_router_present', (root/'0_kernel/lib/archive_method_router_v1.py').exists(), 'warning', 'archive_method_router_v1.py', 'Archive fallback unavailable; restore router if exports are flaky.')
    z7 = root/'tools/7zip/7zz'
    add('7zz_present', z7.exists(), 'warning', str(z7), 'Install or restore 7zz fallback archive validator.')
    add('latest_receipt_present', latest_file(root, ['runtime/receipts/**/*.json','receipts/**/*.json']) is not None, 'warning', latest_file(root, ['runtime/receipts/**/*.json','receipts/**/*.json']), 'Run a governed stage to create a receipt.')
    add('latest_handoff_present', latest_file(root, ['runtime/handoffs/**/*.json','handoffs/**/*.json']) is not None, 'warning', latest_file(root, ['runtime/handoffs/**/*.json','handoffs/**/*.json']), 'Run a governed stage to create a handoff.')
    add('git_dir_present', (root/'.git').exists(), 'info', '.git', 'Non-blocking in ChatGPT artifact runtime.')
    if args.deep:
        try:
            proc = subprocess.run(['python3','-S',str(boot_exec)], cwd=str(root), text=True, capture_output=True, timeout=args.timeout)
            add('deep_boot_smoke', proc.returncode == 0, 'critical', {'returncode': proc.returncode, 'stdout_tail': proc.stdout[-1000:], 'stderr_tail': proc.stderr[-1000:]}, 'Inspect boot executor output and latest boot receipt.')
        except Exception as e:
            add('deep_boot_smoke', False, 'critical', repr(e), 'Run mb boot --json for detailed failure.')
    failed_critical = [c['id'] for c in checks if (not c['ok'] and c['severity'] == 'critical')]
    warnings = [c['id'] for c in checks if (not c['ok'] and c['severity'] == 'warning')]
    verdict = 'DOCTOR_FAIL' if failed_critical else ('DOCTOR_PASS_WITH_WARNINGS' if warnings else 'DOCTOR_PASS')
    out = {'verdict': verdict, 'root': str(root), 'checks': checks, 'failed_checks': failed_critical, 'warnings': warnings, 'deep': args.deep}
    emit(out, args.json)
    return 0 if not failed_critical else 2



def command_breaker(args):
    root = find_root()
    script = root / '0_kernel/scripts/runaway_turn_breaker_v1.py'
    if not script.exists():
        emit({'verdict':'RUNAWAY_BREAKER_NOT_INSTALLED','root':str(root),'required_script':str(script)}, args.json); return 2
    cmd = [sys.executable,'-S',str(script),'--stage-name',args.stage_name or 'UNSPECIFIED_STAGE','--mode','preflight' if args.preflight else 'status','--timeout',str(args.timeout),'--command-count',str(args.command_count),'--files-touched',str(args.files_touched),'--trace-metadata-bytes',str(args.trace_metadata_bytes),'--json']
    if args.broad_extract: cmd.append('--broad-extract')
    if args.allow_broad_extract: cmd.append('--allow-broad-extract')
    if args.has_receipt_plan: cmd.append('--has-receipt-plan')
    if args.has_handoff_plan: cmd.append('--has-handoff-plan')
    proc = subprocess.run(cmd, cwd=str(root), text=True, capture_output=True, timeout=min(max(args.timeout, 5), 20))
    try: payload=json.loads(proc.stdout)
    except Exception: payload={'verdict':'RUNAWAY_BREAKER_COMMAND_ERROR','returncode':proc.returncode,'stdout_tail':proc.stdout[-1000:],'stderr_tail':proc.stderr[-1000:]}
    emit(payload,args.json)
    return proc.returncode


def command_run_stage(args):
    root = find_root()
    stage_name = args.stage_name.strip()
    if not stage_name:
        raise SystemExit('STAGE_NAME_REQUIRED')
    latest_handoff = latest_file(root, ['runtime/handoffs/**/*.json','handoffs/**/*.json'])
    thread_id = stage_thread_id(stage_name)
    checkpoint_id = checkpoint_id_for(stage_name)
    runner_contract_path = root / '0_kernel/registry/operator_surface/MB_STAGE_RUNNER_CONTRACT_v1.json'
    work_order = {
        'artifact_type': 'MB_RUN_STAGE_WORK_ORDER_v2',
        'contract_id': 'MB_STAGE_RUNNER_CONTRACT_v1',
        'created_utc': utc_now(),
        'stage_name': stage_name,
        'thread_id': thread_id,
        'checkpoint_id': checkpoint_id,
        'root': str(root),
        'mode': 'execute' if args.execute else 'dry_run',
        'runner_contract_path': str(runner_contract_path),
        'latest_handoff': latest_handoff,
        'scope': {'bounded_stage_only': True, 'requires_receipt': True, 'requires_handoff': True, 'requires_validation': True, 'requires_tracker_preview': True, 'requires_checkpoint': True},
        'planned_commands': ['load latest handoff', 'validate stage cartridge/spec', 'open checkpoint thread', 'execute one bounded stage', 'write receipt', 'write handoff', 'write tracker preview', 'stop'],
        'fail_closed_rules': ['no hidden chat state', 'no unbounded recursion', 'no success without artifacts'],
    }
    wo_path = root / 'runtime/work_orders/operator_surface' / f'{stage_name}_WORK_ORDER_{utc_now()}.json'
    if not args.no_write:
        write_json(wo_path, work_order)
    breaker = root / '0_kernel/scripts/runaway_turn_breaker_v1.py'
    if breaker.exists():
        br_cmd = [sys.executable,'-S',str(breaker),'--stage-name',stage_name,'--mode','run-stage-execute' if args.execute else 'run-stage-dry-run','--timeout',str(args.timeout),'--command-count',str(len(work_order.get('planned_commands',[]))),'--files-touched','40','--has-receipt-plan','--has-handoff-plan','--json']
        br = subprocess.run(br_cmd, cwd=str(root), text=True, capture_output=True, timeout=min(max(args.timeout,5),20))
        try: br_payload = json.loads(br.stdout)
        except Exception: br_payload = {'verdict':'RUNAWAY_BREAKER_ERROR','stdout_tail':br.stdout[-1000:],'stderr_tail':br.stderr[-1000:]}
        if br.returncode != 0 or br_payload.get('verdict') != 'RUNAWAY_BUDGET_PASS':
            out = {'verdict':'RUN_STAGE_BLOCKED_BY_RUNAWAY_BREAKER','root':str(root),'stage_name':stage_name,'thread_id':thread_id,'checkpoint_id':checkpoint_id,'work_order_path':str(wo_path) if not args.no_write else None,'breaker':br_payload}
            emit(out, args.json)
            return 124
    runner = root / '0_kernel/scripts/stage_runner_v1.py'
    if args.execute:
        if not runner.exists():
            out = {'verdict': 'RUN_STAGE_EXECUTOR_NOT_WIRED', 'root': str(root), 'stage_name': stage_name, 'thread_id': thread_id, 'checkpoint_id': checkpoint_id, 'work_order_path': str(wo_path) if not args.no_write else None, 'required_runner': str(runner), 'next_action': 'Install a stage runner cartridge or execute this stage through governed ChatGPT tooling.'}
            emit(out, args.json)
            return 3
        proc = subprocess.run(['python3','-S',str(runner), stage_name, '--work-order', str(wo_path)], cwd=str(root), text=True, capture_output=True, timeout=args.timeout)
        if proc.returncode == 0:
            run_verdict = 'RUN_STAGE_PASS'
        elif 'STAGE_RUNNER_CONTRACT_ONLY' in proc.stdout:
            run_verdict = 'RUN_STAGE_CONTRACT_ONLY'
        else:
            run_verdict = 'RUN_STAGE_FAIL'
        out = {'verdict': run_verdict, 'root': str(root), 'stage_name': stage_name, 'thread_id': thread_id, 'checkpoint_id': checkpoint_id, 'work_order_path': str(wo_path), 'returncode': proc.returncode, 'stdout_tail': proc.stdout[-2000:], 'stderr_tail': proc.stderr[-2000:]}
        emit(out, args.json)
        return 0 if proc.returncode == 0 else proc.returncode
    out = {'verdict': 'RUN_STAGE_DRY_RUN_READY', 'root': str(root), 'stage_name': stage_name, 'thread_id': thread_id, 'checkpoint_id': checkpoint_id, 'work_order_path': str(wo_path) if not args.no_write else None, 'latest_handoff': latest_handoff, 'execute_command': f'mb run-stage {stage_name} --execute --json', 'work_order': work_order}
    emit(out, args.json)
    return 0



def command_tracker(args):
    root = find_root()
    preview = render_tracker_preview(root, limit=args.limit)
    out = {
        'verdict': 'TRACKER_PREVIEW_READY' if preview['tracker_state_present'] else 'TRACKER_STATE_MISSING',
        'root': str(root),
        'tracker_state_path': preview['tracker_state_path'],
        'tracker_preview': preview['preview_lines'],
        'current_stage': preview['current_stage'],
        'completed_count': preview['completed_count'],
        'blocker': preview['blocker'],
    }
    if args.write:
        path = root / 'runtime/state/operator_surface/TRACKER_PREVIEW_LATEST.txt'
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text('\n'.join(preview['preview_lines']) + '\n', encoding='utf-8')
        out['tracker_preview_path'] = str(path)
    emit(out, args.json)
    return 0 if preview['tracker_state_present'] else 2



def command_trace(args):
    root = find_root()
    candidate_ledgers = [root / 'runtime/traces/observability/TRACE_SPAN_LEDGER_LATEST.jsonl', root / 'runtime/traces/operator_surface/TRACE_LEDGER_LATEST.jsonl']
    ledger = next((p for p in candidate_ledgers if p.exists()), candidate_ledgers[0])
    records = []
    parse_errors = []
    if ledger.exists():
        for idx, line in enumerate(ledger.read_text(encoding='utf-8').splitlines(), start=1):
            if not line.strip():
                continue
            try:
                rec = json.loads(line)
            except Exception as e:
                parse_errors.append({'line_number': idx, 'error': str(e), 'line': line[:300]})
                continue
            if args.stage and rec.get('stage_name') != args.stage:
                continue
            if args.status and rec.get('status') != args.status:
                continue
            records.append(rec)
    returned = records[-args.limit:] if args.limit else records
    by_status = {}
    by_stage = {}
    trace_ids = set()
    for rec in records:
        by_status[rec.get('status','UNKNOWN')] = by_status.get(rec.get('status','UNKNOWN'), 0) + 1
        by_stage[rec.get('stage_name','UNKNOWN')] = by_stage.get(rec.get('stage_name','UNKNOWN'), 0) + 1
        if rec.get('trace_id'):
            trace_ids.add(rec.get('trace_id'))
    summary = {'ledger_path': str(ledger), 'total_matching_records': len(records), 'record_count_returned': len(returned), 'unique_trace_count': len(trace_ids), 'by_status': by_status, 'by_stage': by_stage, 'parse_error_count': len(parse_errors)}
    out = {'verdict': 'TRACE_LEDGER_READY' if ledger.exists() and not parse_errors else ('TRACE_LEDGER_PARSE_WARNINGS' if ledger.exists() else 'TRACE_LEDGER_MISSING'), 'root': str(root), 'trace_ledger_path': str(ledger), 'summary': summary, 'records': returned, 'parse_errors': parse_errors[:10]}
    if args.write_summary:
        path = root / 'runtime/traces/observability/TRACE_SUMMARY_LATEST.json'
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(json.dumps({'artifact_type':'MB_TRACE_SUMMARY_v1','created_utc':utc_now(),'summary':summary}, indent=2, sort_keys=True)+'\n', encoding='utf-8')
        out['summary_path'] = str(path)
    emit(out, args.json)
    return 0 if ledger.exists() else 2


def load_security_artifacts(root: Path):
    threat_model = root / '0_kernel/registry/security/SECURITY_ARTIFACT_THREAT_MODEL_v1.json'
    policy = root / '0_kernel/registry/security/SECURITY_ARTIFACT_TRUST_POLICY_v1.json'
    validation = root / 'runtime/evals/security/SECURITY_ARTIFACT_THREAT_MODEL_STAGE1_VALIDATION_LATEST.json'
    gates = root / '0_kernel/registry/security/SECURITY_ARTIFACT_ENFORCEMENT_GATES_v1.json'
    fixtures = root / '0_kernel/registry/security/SECURITY_PROMPT_INJECTION_FIXTURE_SET_v1.json'
    stage2_validation = root / 'runtime/evals/security/SECURITY_ARTIFACT_THREAT_MODEL_STAGE2_VALIDATION_LATEST.json'
    return threat_model, policy, validation, gates, fixtures, stage2_validation


def command_security(args):
    root = find_root()
    threat_model, policy, validation, gates, fixtures, stage2_validation = load_security_artifacts(root)
    artifacts = {'threat_model': str(threat_model), 'trust_policy': str(policy), 'stage1_validation': str(validation), 'enforcement_gates': str(gates), 'prompt_injection_fixtures': str(fixtures), 'stage2_validation': str(stage2_validation)}
    missing = [name for name, path in artifacts.items() if name != 'stage2_validation' and not Path(path).exists()]
    payload = safe_load_json(threat_model) if threat_model.exists() else None
    gate_payload = safe_load_json(gates) if gates.exists() else None
    fixture_payload = safe_load_json(fixtures) if fixtures.exists() else None
    risk_count = len(payload.get('risks', [])) if isinstance(payload, dict) and isinstance(payload.get('risks'), list) else 0
    gate_count = len(gate_payload.get('gates', [])) if isinstance(gate_payload, dict) and isinstance(gate_payload.get('gates'), list) else 0
    fixture_count = len(fixture_payload.get('fixtures', [])) if isinstance(fixture_payload, dict) and isinstance(fixture_payload.get('fixtures'), list) else 0
    command_count = len(payload.get('security_commands', [])) if isinstance(payload, dict) and isinstance(payload.get('security_commands'), list) else 0
    if getattr(args, 'red_team', False):
        validator = root / '0_kernel/validators/validate_security_red_team_stage4_v1.py'
        runner = root / '0_kernel/scripts/security_red_team_runner_v1.py'
        if not validator.exists() or not runner.exists():
            out = {'verdict': 'SECURITY_RED_TEAM_STAGE4_MISSING', 'root': str(root), 'required_validator': str(validator), 'required_runner': str(runner)}
            emit(out, args.json); return 2
        proc = subprocess.run(['python3','-S',str(validator)], cwd=str(root), text=True, capture_output=True, timeout=args.timeout)
        out = {'verdict': 'SECURITY_RED_TEAM_STAGE4_PASS' if proc.returncode == 0 else 'SECURITY_RED_TEAM_STAGE4_FAIL', 'root': str(root), 'validator_returncode': proc.returncode, 'stdout_tail': proc.stdout[-3000:], 'stderr_tail': proc.stderr[-2000:]}
        emit(out, args.json); return 0 if proc.returncode == 0 else proc.returncode
    if args.fixtures or args.gate_check:
        validator = root / '0_kernel/validators/validate_security_enforcement_stage2_v1.py'
        if not validator.exists():
            out = {'verdict': 'SECURITY_STAGE2_VALIDATOR_MISSING', 'root': str(root), 'artifacts': artifacts, 'missing': missing, 'required_validator': str(validator)}
            emit(out, args.json); return 2
        proc = subprocess.run(['python3','-S',str(validator)], cwd=str(root), text=True, capture_output=True, timeout=args.timeout)
        out = {'verdict': 'SECURITY_STAGE2_CHECK_PASS' if proc.returncode == 0 else 'SECURITY_STAGE2_CHECK_FAIL', 'root': str(root), 'artifacts': artifacts, 'missing': missing, 'risk_count': risk_count, 'gate_count': gate_count, 'fixture_count': fixture_count, 'validator_returncode': proc.returncode, 'stdout_tail': proc.stdout[-2000:], 'stderr_tail': proc.stderr[-2000:]}
        emit(out, args.json); return 0 if proc.returncode == 0 else proc.returncode
    if args.check:
        validator = root / '0_kernel/validators/validate_security_artifact_threat_model_stage1_v1.py'
        if not validator.exists():
            out = {'verdict': 'SECURITY_VALIDATOR_MISSING', 'root': str(root), 'artifacts': artifacts, 'missing': missing, 'required_validator': str(validator)}
            emit(out, args.json); return 2
        proc = subprocess.run(['python3','-S',str(validator)], cwd=str(root), text=True, capture_output=True, timeout=args.timeout)
        out = {'verdict': 'SECURITY_CHECK_PASS' if proc.returncode == 0 else 'SECURITY_CHECK_FAIL', 'root': str(root), 'artifacts': artifacts, 'missing': missing, 'risk_count': risk_count, 'security_command_count': command_count, 'validator_returncode': proc.returncode, 'stdout_tail': proc.stdout[-2000:], 'stderr_tail': proc.stderr[-2000:]}
        emit(out, args.json); return 0 if proc.returncode == 0 else proc.returncode
    out = {'verdict': 'SECURITY_ENFORCEMENT_READY' if not missing else 'SECURITY_ARTIFACTS_MISSING', 'root': str(root), 'artifacts': artifacts, 'missing': missing, 'risk_count': risk_count, 'gate_count': gate_count, 'fixture_count': fixture_count, 'security_command_count': command_count, 'critical_controls': payload.get('critical_controls', []) if isinstance(payload, dict) else []}
    emit(out, args.json); return 0 if not missing else 2



def load_evals_artifacts(root: Path):
    spec = root / '0_kernel/registry/evals/MB_EVALS_TRACE_REVIEW_AND_VALIDATOR_ALIGNMENT_SPEC_v1.json'
    dataset_schema = root / '0_kernel/registry/evals/EVALS_TRACE_REVIEW_DATASET_SCHEMA_v1.json'
