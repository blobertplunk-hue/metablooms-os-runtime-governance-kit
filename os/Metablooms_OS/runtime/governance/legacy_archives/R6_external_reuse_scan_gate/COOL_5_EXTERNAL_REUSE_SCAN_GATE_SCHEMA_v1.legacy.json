    },
    "asset_type": {
      "type": "string",
      "required": true,
      "enum": [
        "schema",
        "validator",
        "component",
        "html_engine",
        "telemetry",
        "dashboard",
        "cartridge",
        "workflow",
        "runner_phase",
        "gate"
      ]
    },
    "asset_name": {
      "type": "string",
      "required": true
    },
    "reuse_decision": {
      "type": "string",
