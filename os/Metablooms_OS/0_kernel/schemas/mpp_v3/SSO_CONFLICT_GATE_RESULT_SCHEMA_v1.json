{
  "$id": "metablooms://schemas/mpp_v3/SSO_CONFLICT_GATE_RESULT_SCHEMA_v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "conflicts": {
      "items": {
        "type": "object"
      },
      "type": "array"
    },
    "created_at": {
      "minLength": 10,
      "type": "string"
    },
    "gate_id": {
      "minLength": 6,
      "type": "string"
    },
    "packet_id": {
      "minLength": 8,
      "type": "string"
    },
    "result_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "schema_version": {
      "const": "mpp.sso_conflict_gate_result.v1"
    },
    "stage": {
      "const": "SSO_CONFLICT_GATE"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL"
      ],
      "type": "string"
    },
    "violations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "gate_id",
    "stage",
    "created_at",
    "packet_id",
    "verdict",
    "violations",
    "warnings",
    "conflicts",
    "result_hash"
  ],
  "title": "MPP v3 SSO Conflict Gate Result",
  "type": "object"
}
