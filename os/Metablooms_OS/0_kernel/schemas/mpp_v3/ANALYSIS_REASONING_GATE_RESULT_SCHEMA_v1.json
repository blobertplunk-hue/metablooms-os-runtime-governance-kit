{
  "$id": "metablooms://schemas/mpp_v3/ANALYSIS_REASONING_GATE_RESULT_SCHEMA_v1",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "created_at": {
      "minLength": 10,
      "type": "string"
    },
    "gate_id": {
      "minLength": 6,
      "type": "string"
    },
    "packet_id": {
      "minLength": 8,
      "type": "string"
    },
    "result_hash": {
      "pattern": "^[a-f0-9]{64}$",
      "type": "string"
    },
    "routing": {
      "type": "object"
    },
    "schema_version": {
      "const": "mpp.analysis_reasoning_gate_result.v1"
    },
    "stage": {
      "const": "ANALYSIS_REASONING_GATE"
    },
    "verdict": {
      "enum": [
        "PASS",
        "FAIL",
        "NEEDS_REPAIR"
      ],
      "type": "string"
    },
    "violations": {
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "warnings": {
      "items": {
        "type": "string"
      },
      "type": "array"
    }
  },
  "required": [
    "schema_version",
    "gate_id",
    "stage",
    "created_at",
    "packet_id",
    "verdict",
    "violations",
    "warnings",
    "routing",
    "result_hash"
  ],
  "title": "MPP v3 Analysis Reasoning Gate Result",
  "type": "object"
}
